{
  "expo": {
    "name": "Sprout Detective",
    "slug": "sprout-detective",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sprout.detective"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      },
      "package": "com.sprout.detective",
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "webpack"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Sprout Detective to use your camera to identify objects!"
        }
      ]
    ]
  }
}
